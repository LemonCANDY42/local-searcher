{
  "name": "agent-searchkit",
  "version": "0.3.19",
  "description": "Local-first SearXNG search + reranking + research pipelines for AI agents. Framework-agnostic.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LemonCANDY42/agent-searchkit.git"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --external:openclaw --external:node-llama-cpp",
    "test": "node src/index.test.mjs && node scripts/lib/search-benchmark-core.test.mjs",
    "test:mcp": "node scripts/smoke-mcp.mjs",
    "test:rollout": "node scripts/validate-agent-searchkit-rollout.mjs"
  },
  "keywords": [
    "searxng",
    "search",
    "reranking",
    "ai-agent",
    "openclaw",
    "mcp",
    "local-first",
    "research-pipeline"
  ],
  "files": [
    "bin/",
    "dist/",
    "docs/",
    "openclaw.plugin.json",
    "scripts/",
    "services/",
    "!services/.env.local",
    "skills/",
    "src/",
    "CHANGELOG.md",
    "LICENSE",
    "README.md"
  ],
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ],
    "runtimeExtensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.24-beta.2",
      "minGatewayVersion": "2026.3.24-beta.2"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    }
  },
  "devDependencies": {
    "esbuild": "^0.28.0"
  },
  "bin": {
    "agent-searchkit": "bin/agent-searchkit-mcp",
    "agent-searchkit-search": "bin/agent-searchkit-search",
    "agent-searchkit-research": "bin/agent-searchkit-research",
    "agent-searchkit-mcp": "bin/agent-searchkit-mcp"
  }
}
